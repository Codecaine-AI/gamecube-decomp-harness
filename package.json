{
  "name": "melee-decomp-orchestrator",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "orch": "bun src/bin/decomp-orchestrator.ts",
    "ui": "bun run ui:build && bun run ui:server",
    "ui:server": "bun src/ui/server.ts",
    "ui:dev": "bun run ui:build && sh -c 'bun run ui:watch & WATCH_PID=$!; trap \"kill $WATCH_PID 2>/dev/null\" EXIT; ORCH_UI_HOT_RELOAD=1 bun src/ui/server.ts'",
    "ui:dev:hot-server": "bun run ui:build && sh -c 'bun run ui:watch & WATCH_PID=$!; trap \"kill $WATCH_PID 2>/dev/null\" EXIT; ORCH_UI_HOT_RELOAD=1 bun --hot --no-clear-screen src/ui/server.ts'",
    "ui:build": "vite build --config src/ui/app/vite.config.ts",
    "ui:watch": "vite build --watch --config src/ui/app/vite.config.ts",
    "ui:check": "tsc --noEmit -p src/ui/app/tsconfig.json",
    "check": "tsc --noEmit && bun run ui:check",
    "smoke": "bun tests/smoke.ts",
    "regression-check": "bun src/bin/decomp-orchestrator.ts regression-check",
    "kg:sources": "bun src/bin/decomp-orchestrator.ts kg-sources",
    "kg:status": "bun src/bin/decomp-orchestrator.ts kg-status",
    "kg:import-agent-state": "bun src/bin/decomp-orchestrator.ts kg-import-agent-state",
    "kg:curate": "bun src/bin/decomp-orchestrator.ts kg-curate",
    "kg:maintain": "bun src/bin/decomp-orchestrator.ts kg-maintain",
    "kg:rebuild": "bun src/bin/decomp-orchestrator.ts kg-rebuild-graph",
    "kg:search": "bun src/bin/decomp-orchestrator.ts kg-search",
    "kg:smoke": "bun src/bin/decomp-orchestrator.ts kg-smoke",
    "kg:file-card": "bun src/bin/decomp-orchestrator.ts kg-file-card",
    "kg:rank-features": "bun src/bin/decomp-orchestrator.ts kg-rank-features",
    "kg:tool-indexes": "python3 knowledge/tools/build_tool_indexes.py",
    "kg:tool-runner:ghidra": "python3 knowledge/tools/ghidra/runners/run_headless_probe.py",
    "kg:tool-runner:opseq": "python3 knowledge/tools/opseq/runners/extract_opcode_sequences.py",
    "kg:tool-runner:mismatch-db": "python3 knowledge/tools/mismatch_db/runners/analyze_objdiff_mismatches.py",
    "kg:tool-runner:mwcc-debug": "python3 knowledge/tools/mwcc_debug/runners/probe_mwcc_compiler.py",
    "pr:refresh": "python3 knowledge/sources/past_prs/commands/fetch_recent_pr_dump.py",
    "pr:refresh:all": "python3 knowledge/sources/past_prs/commands/fetch_recent_pr_dump.py --all-prs --fetch-jobs 16 --postmortem-mode pi --postmortem-jobs 16 --postmortem-scope all",
    "pr:refresh:dry": "python3 knowledge/sources/past_prs/commands/fetch_recent_pr_dump.py --dry-run",
    "pr:postmortems": "python3 knowledge/sources/past_prs/commands/build_pr_postmortems.py",
    "pr:sync": "python3 knowledge/sources/past_prs/commands/sync_repo_and_pr_library.py",
    "pr:sync:all": "python3 knowledge/sources/past_prs/commands/sync_repo_and_pr_library.py --all-prs --fetch-jobs 16 --postmortem-jobs 16"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "latest",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "latest",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "bun-types": "latest",
    "tailwindcss": "^4.3.0",
    "typescript": "latest",
    "vite": "^8.0.16"
  }
}
