{
  "name": "melee-decomp-orchestrator",
  "private": true,
  "type": "module",
  "scripts": {
    "orch": "bun src/bin/decomp-orchestrator.ts",
    "check": "tsc --noEmit",
    "smoke": "bun tests/smoke.ts",
    "regression-check": "bun src/bin/decomp-orchestrator.ts regression-check",
    "pr:refresh": "python3 knowledge/past_prs/utils/fetch_recent_pr_dump.py",
    "pr:refresh:dry": "python3 knowledge/past_prs/utils/fetch_recent_pr_dump.py --dry-run",
    "pr:postmortems": "python3 knowledge/past_prs/utils/build_pr_postmortems.py",
    "pr:sync": "python3 knowledge/past_prs/utils/sync_repo_and_pr_library.py"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "bun-types": "latest",
    "typescript": "latest"
  }
}
