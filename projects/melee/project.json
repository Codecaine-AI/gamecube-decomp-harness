{
  "id": "melee",
  "displayName": "Super Smash Bros. Melee",
  "kind": "doldecomp-melee",
  "repoRoot": "./checkout",
  "stateDir": "./state",
  "graphDb": "./graph/graph.sqlite",
  "processName": "melee-live",
  "baseRef": "origin/master",
  "localEnv": "./local.env",
  "validation": {
    "qaTarget": "changes_all",
    "reportPath": "build/GALE01/report.json",
    "reportChangesPath": "build/GALE01/report_changes.json",
    "objdiffPath": "objdiff.json"
  },
  "dashboard": {
    "epochSize": 128,
    "agentTimeoutSeconds": 3000,
    "goalValue": 100
  },
  "pr": {
    "groupMode": "melee-subsystem",
    "titlePrefix": "Melee decomp",
    "branchPrefix": "decomp",
    "maxFilesPerPr": 8,
    "splitStrategy": "agent",
    "improvementMinGainPoints": 2.0,
    "improvementMinMatchedBytes": 64
  },
  "knowledge": {
    "globalSources": [
      "past_prs",
      "decomp_standards",
      "ssbm_data_sheet",
      "powerpc_docs",
      "external_mirrors",
      "path_facts"
    ],
    "projectSources": [
      "code_graph"
    ]
  },
  "tools": {
    "toolpacks": [
      "gamecube-decomp"
    ],
    "bindingsRoot": "./tool-bindings",
    "sharedDataRoot": "./shared/tool-data",
    "worktreeCacheRoot": "./worktrees/{worktree_id}/tool-cache"
  }
}
