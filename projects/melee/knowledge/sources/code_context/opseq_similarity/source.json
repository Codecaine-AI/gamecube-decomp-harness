{
  "id": "opseq_similarity",
  "kind": "tool_evidence",
  "title": "Opseq similarity evidence",
  "trust_tier": "tool_evidence",
  "freshness": "generated",
  "section": "code_context",
  "access_modes": [
    "file_card",
    "rank_features",
    "graph_search",
    "source_search",
    "symbol_lookup"
  ],
  "description": "Opcode-sequence neighbor evidence generated by the opseq research tool and attached to current code-graph functions.",
  "data_paths": [
    "projects/melee/shared/tool-data/opseq/indexes"
  ],
  "index_outputs": [
    "projects/melee/shared/tool-data/opseq/indexes/functions.jsonl",
    "projects/melee/shared/tool-data/opseq/indexes/function_shapes.jsonl",
    "projects/melee/shared/tool-data/opseq/indexes/opcode_sequences.jsonl",
    "projects/melee/shared/tool-data/opseq/indexes/opcode_fingerprints.jsonl",
    "projects/melee/shared/tool-data/opseq/indexes/opcode_neighbors.jsonl"
  ],
  "commands": {
    "refresh": "python3 toolpacks/gamecube-decomp/research/opseq/runners/extract_opcode_sequences.py --repo-root <repo_root>",
    "search": "python3 toolpacks/gamecube-decomp/research/opseq/api/similar_functions.py --query <query> --json",
    "index": "bun run kg:rebuild -- --sources code_graph,opseq_similarity",
    "file_card": "bun run kg:file-card -- --source <source_path>",
    "rank_features": "bun run kg:rank-features"
  },
  "capabilities": [
    "instruction_shape_analogs",
    "function_similarity",
    "rank_features"
  ]
}
